{
  "name": "dimelscourse",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @dimelscourse/web",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm run build -w @dimelscourse/web",
    "dev:api": "npm run start:dev -w @dimelscourse/api",
    "build:api": "npm run build -w @dimelscourse/api",
    "seed:api": "npm run seed -w @dimelscourse/api",
    "lint": "eslint apps/",
    "lint:fix": "eslint apps/ --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
